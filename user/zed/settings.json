// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "title_bar": {
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "disable_ai": true,
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "relative_line_numbers": "wrapped",
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte - No Italics",
    "dark": "One Dark",
  },
  "auto_install_extensions": {
    "astro": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "html": true,
    "marksman": true,
    "mdx": true,
    "sql": true,
    "toml": true,
    "vue": true,
    "comment": true,
    "csv": true,
    "markdownlint": true,
    "nix": true,
    "tombi": true,
    "just": true,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "languages": {
    "Markdown": {
      "completions": {
        "words": "enabled",
        "words_min_length": 3,
        "lsp": true,
        "lsp_fetch_timeout_ms": 0,
        "lsp_insert_mode": "replace_suffix",
      },
    },
    "Nix": {
      "language_servers": ["nil", "!nixd"],
      "formatter": {
        "external": {
          "command": "alejandra",
          "arguments": ["--quiet", "--"],
        },
      },
    },
  },
}
